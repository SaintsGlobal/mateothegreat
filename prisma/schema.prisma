generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ExclusiveContent {
  id          String      @id
  title       String
  slug        String      @unique
  content     String
  type        ContentType @default(ARTICLE)
  createdAt   DateTime    @default(now())
  publishedAt DateTime?
}

model NewsletterSubscriber {
  id           String           @id
  email        String           @unique
  status       SubscriberStatus @default(ACTIVE)
  subscribedAt DateTime         @default(now())
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String    @id
  email             String    @unique
  name              String?
  passwordHash      String
  emailVerified     Boolean   @default(false)
  resetToken        String?
  resetTokenExp     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  verificationToken String?
  Session           Session[]
}

enum ContentType {
  ARTICLE
  VIDEO
  ANNOUNCEMENT
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
}

model Newsletter {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  template    String
  content     Json
  author      String
  status      String    @default("draft")
  version     Int       @default(1)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
